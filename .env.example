# Template for local secrets. Copy to `.env` and fill in real values.
# `.env` is gitignored; this template (`.env.example`) IS committed.

# Pick at least one provider key.
OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Live integration tests are gated on this. Set to 1 to enable.
# PYHARNESS_LIVE_API=1

# Override the model used by live scenarios.
# PYHARNESS_LIVE_MODEL=openrouter/anthropic/claude-haiku-4-5
